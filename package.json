{
    "name": "tu-selva-urbana-backend",
    "version": "1.0.0",
    "description": "API REST para Tu Selva Urbana - Vivero Inteligente",
    "main": "src/server.js",
    "scripts": {
        "dev": "nodemon src/server.js",
        "build": "node prisma-build.js",
        "start": "npx prisma db push --accept-data-loss && node prisma/seed.js && node fix-images.js && node src/server.js",
        "db:migrate": "npx prisma migrate dev",
        "db:seed": "node prisma/seed.js",
        "db:studio": "npx prisma studio"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@prisma/client": "^5.11.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "express-validator": "^7.0.1",
        "jsonwebtoken": "^9.0.2",
        "nodemailer": "^8.0.4",
        "twilio": "^5.13.1"
    },
    "devDependencies": {
        "nodemon": "^3.1.0",
        "prisma": "^5.11.0"
    }
}
